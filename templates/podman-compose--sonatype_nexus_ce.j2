---
### https://docs.docker.com/compose/compose-file/

# Don't forget to update the volume mount paths to contain the actual user homedir who will run the containers

volumes:
#  postgres-data:

services:

  nexus-server:
    image: docker.io/sonatype/nexus3:3.87.1
    ports:
      - "8081:8081"
      - "8085:8085"
    environment:
      - TZ=Europe/Budapest
      - LANG=en_US.utf8
    restart: unless-stopped
    volumes:
#      Adding "U" to the mount makes the owner the container default user, for now "nexus"
      - /home/{{ ansible_user }}/container-projects/{{containerhost__container_project_name}}/nexus-data:/nexus-data:U,z,rw
