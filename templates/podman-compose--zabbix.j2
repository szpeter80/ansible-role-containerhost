---
### https://docs.docker.com/compose/compose-file/

networks:
  containerhost:
    external: true

services:

  zabbix-server:
#   https://hub.docker.com/r/zabbix/zabbix-server-pgsql
    image: docker.io/zabbix/zabbix-server-pgsql:{{ containerhost__zabbix__imagetag }}
    networks:
      - containerhost
    ports:
      - 10051:10051
    environment:
      - TZ={{ containerhost__time_zone }}
      - LANG=en_US.utf8
      - DB_SERVER_HOST=postgres
      - DB_SERVER_PORT=5432
      - POSTGRES_DB=zabbix
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=dummy
      - ZBX_STARTREPORTWRITERS=1
      - ZBX_WEBSERVICEURL=http://zabbix-web-service:10053/report
      - ZBX_DEBUGLEVEL=3
    restart: unless-stopped
    volumes:
      - /home/{{ ansible_user }}/container-projects/{{containerhost__container_project_name}}/zabbix-server/ssh-keys:/var/lib/zabbix/ssh_keys:z,ro

  zabbix-web:
    image: docker.io/zabbix/zabbix-web-nginx-pgsql:{{ containerhost__zabbix__imagetag }}
    networks:
      - containerhost
#    ports:
#      - 8080:8080
#      - 8443:8443
    environment:
      - TZ={{ containerhost__time_zone }}
      - PHP_TZ={{ containerhost__time_zone }}
      - LANG=en_US.utf8
      - DB_SERVER_HOST=postgres
      - DB_SERVER_PORT=5432
      - POSTGRES_DB=zabbix
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=dummy
      # UI - friendly display name of the instance
      - ZBX_SERVER_NAME="Zabbix Monitoring"
      - ZBX_SERVER_HOST=zabbix-server
      - ZBX_SERVER_PORT=10051
      - ZBX_DEBUGLEVEL=3
    restart: unless-stopped
    depends_on:
      - zabbix-server

  zabbix-web-service:
    image: docker.io/zabbix/zabbix-web-service:{{ containerhost__zabbix__imagetag }}
    networks:
      - containerhost
    ports:
      - 10053:10053
    environment:
      - TZ={{ containerhost__time_zone }}
      - LANG=en_US.utf8
      - ZBX_HOSTNAME=zabbix-web-service
      - ZBX_ALLOWEDIP=localhost,10.0.0.0/8,192.168.0.0/16,172.0.0.0/8
      - ZBX_TLSACCEPT=unencrypted
      - ZBX_IGNOREURLCERTERRORS=1
      - ZBX_TIMEOUT=30
      - ZBX_DEBUGLEVEL=5
    restart: unless-stopped

  zabbix-agent:
    image: docker.io/zabbix/zabbix-agent2:{{ containerhost__zabbix__imagetag }}
    networks:
      - containerhost
    environment:
      - TZ={{ containerhost__time_zone }}
      - LANG=en_US.utf8
      - ZBX_HOSTNAME=zabbix-agent
      - ZBX_SERVER_HOST="zabbix-server"
      - ZBX_DEBUGLEVEL=3
    restart: unless-stopped
    depends_on:
      - zabbix-server
